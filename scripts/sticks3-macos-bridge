#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import plistlib
import shlex
import shutil
import signal
import subprocess
import sys
import sysconfig
import time
from datetime import datetime
from pathlib import Path
from typing import Any


REPO_ROOT = Path(os.environ.get("STICKS3_REPO", Path(__file__).resolve().parents[1])).expanduser().resolve()
RUNTIME_DIR = Path(os.environ.get("STICKS3_RUNTIME_DIR", REPO_ROOT / "runtime")).expanduser()
PID_FILE = RUNTIME_DIR / "bridge.pid"
STATUS_FILE = RUNTIME_DIR / "bridge-status.json"
LOG_FILE = RUNTIME_DIR / "bridge.log"
APP_DIR = RUNTIME_DIR / "StickS3Bridge.app"
APP_CONTENTS = APP_DIR / "Contents"
APP_MACOS = APP_CONTENTS / "MacOS"
APP_RESOURCES = APP_CONTENTS / "Resources"
APP_EXEC = APP_MACOS / "StickS3BridgeLauncher"
APP_MAIN = APP_RESOURCES / "bridge_app_main.py"
APP_PLIST = APP_CONTENTS / "Info.plist"
APP_PKGINFO = APP_CONTENTS / "PkgInfo"
AGENT_LABEL = "com.simon.sticks3-codex-companion.bridge"
AGENT_PLIST = Path.home() / "Library" / "LaunchAgents" / f"{AGENT_LABEL}.plist"
AGENT_APP_DIR = Path.home() / "Applications" / "StickS3Bridge.app"
BRIDGE_PYTHON_INFO: dict[str, str] | None = None


def now_iso() -> str:
    return datetime.now().astimezone().isoformat(timespec="seconds")


def read_json(path: Path) -> dict[str, Any]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return data if isinstance(data, dict) else {}


def write_status(state: str, *, detail: str | None = None, error: str | None = None) -> None:
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    existing = read_json(STATUS_FILE)
    status_text = error or detail or {
        "starting": "Bridge starting",
        "connecting": "Bridge connecting",
        "stopped": "Bridge stopped",
        "error": "Bridge error",
    }.get(state, state)
    codex_state = {
        "starting": "wait",
        "connecting": "wait",
        "stopped": "off",
        "error": "err",
    }.get(state, existing.get("codex_state") or existing.get("menu_mode") or existing.get("mode") or "wait")
    bridge_state = {
        "starting": "starting",
        "connecting": "starting",
        "stopped": "stopped",
        "error": "error",
    }.get(state, existing.get("bridge_state") or state)
    supervisor_state = {
        "starting": "starting",
        "connecting": "starting",
        "stopped": "stopped",
        "error": "error",
    }.get(state, existing.get("supervisor_state") or bridge_state)
    device_state = {
        "starting": "scanning",
        "connecting": "scanning",
        "stopped": "off",
        "error": "error",
    }.get(state, existing.get("device_state") or state)
    existing.update(
        {
            "state": state,
            "updated_at": now_iso(),
            "pid": read_pid(),
            "bridge_state": bridge_state,
            "supervisor_state": supervisor_state,
            "supervisor_pid": read_pid(),
            "mode": codex_state,
            "menu_mode": codex_state,
            "codex_state": codex_state,
            "device_state": device_state,
            "device_error": error if state == "error" else None,
            "active": False if state in {"starting", "connecting", "stopped", "error"} else existing.get("active"),
            "task_active": False if state in {"starting", "connecting", "stopped", "error"} else existing.get("task_active"),
            "last_message": status_text,
            "status": {
                "speaker": "System",
                "kind": "error" if state == "error" else state,
                "text": status_text,
            },
            "detail": detail,
            "error": error,
        }
    )
    temp_path = STATUS_FILE.with_suffix(STATUS_FILE.suffix + ".tmp")
    temp_path.write_text(json.dumps(existing, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    temp_path.replace(STATUS_FILE)


def read_pid() -> int | None:
    try:
        text = PID_FILE.read_text(encoding="utf-8").strip()
    except OSError:
        return None
    try:
        pid = int(text)
    except ValueError:
        return None
    return pid if pid > 0 else None


def pid_is_running(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def remove_stale_pid() -> None:
    try:
        PID_FILE.unlink()
    except FileNotFoundError:
        pass


def bridge_bin() -> Path:
    local_bin = REPO_ROOT / ".bridge-venv" / "bin" / "sticks3-bridge"
    if local_bin.exists():
        return local_bin
    resolved = shutil.which("sticks3-bridge")
    if resolved:
        return Path(resolved)
    raise RuntimeError(
        "sticks3-bridge is not installed. Run: python3.11 -m venv .bridge-venv && "
        "source .bridge-venv/bin/activate && python -m pip install -e ."
    )


def bridge_args(args: argparse.Namespace) -> list[str]:
    command = [
        "--log-level",
        args.log_level,
        "desktop-observer",
        "--scan-timeout",
        str(args.scan_timeout),
        "--poll-interval",
        str(args.poll_interval),
        "--heartbeat-interval",
        str(args.heartbeat_interval),
        "--idle-heartbeat-interval",
        str(args.idle_heartbeat_interval),
        "--status-file",
        str(STATUS_FILE),
        "--reconnect-delay",
        str(args.reconnect_delay),
        "--max-reconnect-delay",
        str(args.max_reconnect_delay),
    ]
    if not args.reconnect:
        command.append("--no-reconnect")
    if args.device_prefix:
        command.extend(["--device-prefix", args.device_prefix])
    if args.address:
        command.extend(["--address", args.address])
    if args.codex_home:
        command.extend(["--codex-home", args.codex_home])
    if args.sessions_dir:
        command.extend(["--sessions-dir", args.sessions_dir])
    if args.thread_id:
        command.extend(["--thread-id", args.thread_id])
    if args.rollout:
        command.extend(["--rollout", args.rollout])
    if args.fake_device:
        command.append("--fake-device")
    return command


def bridge_command(args: argparse.Namespace) -> list[str]:
    return [str(bridge_bin()), *bridge_args(args)]


def supervisor_option_args(args: argparse.Namespace) -> list[str]:
    command = [
        "--log-level",
        args.log_level,
        "--scan-timeout",
        str(args.scan_timeout),
        "--poll-interval",
        str(args.poll_interval),
        "--heartbeat-interval",
        str(args.heartbeat_interval),
        "--idle-heartbeat-interval",
        str(args.idle_heartbeat_interval),
        "--reconnect-delay",
        str(args.reconnect_delay),
        "--max-reconnect-delay",
        str(args.max_reconnect_delay),
    ]
    if not args.reconnect:
        command.append("--no-reconnect")
    if args.device_prefix:
        command.extend(["--device-prefix", args.device_prefix])
    if args.address:
        command.extend(["--address", args.address])
    if args.codex_home:
        command.extend(["--codex-home", args.codex_home])
    if args.sessions_dir:
        command.extend(["--sessions-dir", args.sessions_dir])
    if args.thread_id:
        command.extend(["--thread-id", args.thread_id])
    if args.rollout:
        command.extend(["--rollout", args.rollout])
    if args.fake_device:
        command.append("--fake-device")
    return command


def python_bin() -> Path:
    local_bin = REPO_ROOT / ".bridge-venv" / "bin" / "python"
    if local_bin.exists():
        return local_bin.resolve()
    return Path(sys.executable).resolve()


def bridge_python_info() -> dict[str, str]:
    global BRIDGE_PYTHON_INFO
    if BRIDGE_PYTHON_INFO is not None:
        return BRIDGE_PYTHON_INFO

    script = (
        "import json, sys, sysconfig; "
        "libdir = sysconfig.get_config_var('LIBDIR') or ''; "
        "print(json.dumps({"
        "'version': f'{sys.version_info.major}.{sys.version_info.minor}', "
        "'executable': sys.executable, "
        "'include': sysconfig.get_config_var('INCLUDEPY') or '', "
        "'libdir': libdir, "
        "'libpl': sysconfig.get_config_var('LIBPL') or libdir, "
        "'ldversion': sysconfig.get_config_var('LDVERSION') or sysconfig.get_config_var('VERSION') or '', "
        "'home': str(__import__('pathlib').Path(libdir).resolve().parent) if libdir else ''"
        "}))"
    )
    result = subprocess.run([str(python_bin()), "-c", script], text=True, capture_output=True)
    if result.returncode == 0:
        try:
            payload = json.loads(result.stdout)
            if isinstance(payload, dict):
                BRIDGE_PYTHON_INFO = {str(key): str(value) for key, value in payload.items()}
                return BRIDGE_PYTHON_INFO
        except json.JSONDecodeError:
            pass

    libdir = sysconfig.get_config_var("LIBDIR") or ""
    BRIDGE_PYTHON_INFO = {
        "version": f"{sys.version_info.major}.{sys.version_info.minor}",
        "executable": str(python_bin()),
        "include": str(sysconfig.get_config_var("INCLUDEPY") or ""),
        "libdir": str(libdir),
        "libpl": str(sysconfig.get_config_var("LIBPL") or libdir),
        "ldversion": str(sysconfig.get_config_var("LDVERSION") or sysconfig.get_config_var("VERSION") or ""),
        "home": str(Path(libdir).resolve().parent) if libdir else "",
    }
    return BRIDGE_PYTHON_INFO


def python_home_dir() -> Path:
    home = bridge_python_info().get("home")
    if home:
        return Path(home)
    return python_bin().parent.parent


def python_config_tool() -> Path | None:
    version = bridge_python_info().get("version") or f"{sys.version_info.major}.{sys.version_info.minor}"
    candidate = python_bin().with_name(f"python{version}-config")
    if candidate.exists():
        return candidate
    resolved = shutil.which(f"python{version}-config")
    return Path(resolved) if resolved else None


def python_config_flags(*args: str) -> list[str]:
    tool = python_config_tool()
    if tool:
        result = subprocess.run([str(tool), *args], text=True, capture_output=True)
        if result.returncode == 0:
            return shlex.split(result.stdout)

    if "--cflags" in args:
        include = bridge_python_info().get("include")
        return [f"-I{include}"] if include else []

    info = bridge_python_info()
    version = info.get("ldversion") or info.get("version")
    libpl = info.get("libpl") or info.get("libdir")
    flags: list[str] = []
    if libpl:
        flags.append(f"-L{libpl}")
    if version:
        flags.append(f"-lpython{version}")
    flags.extend(["-ldl", "-framework", "CoreFoundation"])
    return flags


def app_info_plist() -> str:
    return """<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleDisplayName</key>
  <string>StickS3 Codex Bridge</string>
  <key>CFBundleExecutable</key>
  <string>StickS3BridgeLauncher</string>
  <key>CFBundleIdentifier</key>
  <string>com.simon.sticks3bridge.helper</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>StickS3 Codex Bridge</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>StickS3 Codex Bridge uses Bluetooth to connect to Simon's M5Stack StickS3 dashboard.</string>
  <key>NSBluetoothPeripheralUsageDescription</key>
  <string>StickS3 Codex Bridge uses Bluetooth to connect to Simon's M5Stack StickS3 dashboard.</string>
</dict>
</plist>
"""


def app_launcher_source() -> str:
    return f"""#include <stdio.h>
#include <stdlib.h>
#include <Python.h>

int main(int argc, char *argv[]) {{
    if (argc < 2) {{
        fprintf(stderr, "missing bridge app main path\\n");
        return 64;
    }}

    PyStatus status;
    PyConfig config;
    PyConfig_InitPythonConfig(&config);
    config.use_environment = 1;
    config.site_import = 1;
    config.parse_argv = 0;

    status = PyConfig_SetBytesString(&config, &config.program_name, argv[0]);
    if (PyStatus_Exception(status)) {{
        Py_ExitStatusException(status);
    }}
    status = PyConfig_SetBytesString(&config, &config.executable, {json.dumps(str(python_bin()))});
    if (PyStatus_Exception(status)) {{
        Py_ExitStatusException(status);
    }}
    status = PyConfig_SetBytesString(&config, &config.home, {json.dumps(str(python_home_dir()))});
    if (PyStatus_Exception(status)) {{
        Py_ExitStatusException(status);
    }}
    status = PyConfig_SetBytesArgv(&config, argc - 1, argv + 1);
    if (PyStatus_Exception(status)) {{
        Py_ExitStatusException(status);
    }}

    status = Py_InitializeFromConfig(&config);
    PyConfig_Clear(&config);
    if (PyStatus_Exception(status)) {{
        Py_ExitStatusException(status);
    }}

    FILE *fp = fopen(argv[1], "r");
    if (!fp) {{
        perror(argv[1]);
        Py_FinalizeEx();
        return 66;
    }}

    int result = PyRun_SimpleFileExFlags(fp, argv[1], 1, NULL);
    int final_result = Py_FinalizeEx();
    if (final_result < 0) {{
        return 120;
    }}
    return result == 0 ? 0 : 1;
}}
"""


def app_main_source() -> str:
    return f"""from __future__ import annotations

import json
import os
import sys
from datetime import datetime
from pathlib import Path

REPO_ROOT = Path({str(REPO_ROOT)!r})
RUNTIME_DIR = Path(os.environ.get("STICKS3_RUNTIME_DIR", REPO_ROOT / "runtime")).expanduser()
PID_FILE = RUNTIME_DIR / "bridge.pid"
STATUS_FILE = RUNTIME_DIR / "bridge-status.json"
LOG_FILE = RUNTIME_DIR / "bridge.log"

RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
PID_FILE.write_text(f"{{os.getpid()}}\\n", encoding="utf-8")

log = LOG_FILE.open("ab", buffering=0)
os.dup2(log.fileno(), 1)
os.dup2(log.fileno(), 2)
print(f"\\n[app {{os.getpid()}}] starting StickS3 bridge", flush=True)

version = f"python{{sys.version_info.major}}.{{sys.version_info.minor}}"
site_packages = REPO_ROOT / ".bridge-venv" / "lib" / version / "site-packages"
bridge_src = REPO_ROOT / "bridge"
for path in (str(site_packages), str(bridge_src)):
    if path not in sys.path:
        sys.path.insert(0, path)

os.environ.setdefault("STICKS3_REPO", str(REPO_ROOT))
os.chdir(REPO_ROOT)

try:
    from sticks3_bridge.cli import main
    raise SystemExit(main(sys.argv[1:]))
finally:
    try:
        payload = {{}}
        if STATUS_FILE.exists():
            payload = json.loads(STATUS_FILE.read_text(encoding="utf-8"))
            if not isinstance(payload, dict):
                payload = {{}}
        if payload.get("pid") in (None, os.getpid()):
            payload.update({{
                "state": "stopped",
                "mode": "off",
                "menu_mode": "off",
                "codex_state": "off",
                "bridge_state": "stopped",
                "supervisor_state": "stopped",
                "supervisor_pid": None,
                "device_state": "off",
                "device_error": None,
                "active": False,
                "task_active": False,
                "updated_at": datetime.now().astimezone().isoformat(timespec="seconds"),
                "detail": "Bridge process exited",
                "last_message": "Bridge process exited",
                "status": {{"speaker": "System", "kind": "stopped", "text": "Bridge process exited"}},
            }})
            temp_path = STATUS_FILE.with_suffix(STATUS_FILE.suffix + ".tmp")
            temp_path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\\n", encoding="utf-8")
            temp_path.replace(STATUS_FILE)
    except Exception:
        pass
    try:
        if PID_FILE.read_text(encoding="utf-8").strip() == str(os.getpid()):
            PID_FILE.unlink()
    except OSError:
        pass
"""


def sign_app_bundle(app_dir: Path) -> None:
    codesign = shutil.which("codesign") or "/usr/bin/codesign"
    result = subprocess.run(
        [codesign, "--force", "--deep", "--sign", "-", str(app_dir)],
        text=True,
        capture_output=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "codesign failed"
        raise RuntimeError(f"Could not sign {app_dir}: {message}")


def app_paths(app_dir: Path) -> dict[str, Path]:
    contents = app_dir / "Contents"
    return {
        "contents": contents,
        "macos": contents / "MacOS",
        "resources": contents / "Resources",
        "exec": contents / "MacOS" / "StickS3BridgeLauncher",
        "main": contents / "Resources" / "bridge_app_main.py",
        "plist": contents / "Info.plist",
        "pkginfo": contents / "PkgInfo",
        "launcher_source": contents / "Resources" / "launcher.c",
    }


def text_matches(path: Path, desired: str) -> bool:
    try:
        return path.read_text(encoding="utf-8") == desired
    except OSError:
        return False


def write_text_if_changed(path: Path, desired: str, *, encoding: str = "utf-8") -> bool:
    if text_matches(path, desired):
        return False
    path.write_text(desired, encoding=encoding)
    return True


def app_bundle_current(app_dir: Path) -> bool:
    paths = app_paths(app_dir)
    return (
        paths["exec"].exists()
        and text_matches(paths["plist"], app_info_plist())
        and text_matches(paths["pkginfo"], "APPL????")
        and text_matches(paths["main"], app_main_source())
        and text_matches(paths["launcher_source"], app_launcher_source())
    )


def build_app_launcher() -> None:
    clang = shutil.which("clang") or "/usr/bin/clang"
    launcher_source = APP_RESOURCES / "launcher.c"
    cflags = python_config_flags("--embed", "--cflags")
    ldflags = python_config_flags("--embed", "--ldflags")
    result = subprocess.run(
        [clang, *cflags, "-Os", str(launcher_source), "-o", str(APP_EXEC), *ldflags],
        text=True,
        capture_output=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "clang failed"
        raise RuntimeError(f"Could not build StickS3 bridge app launcher: {message}")
    APP_EXEC.chmod(0o755)


def ensure_bridge_app() -> Path:
    APP_MACOS.mkdir(parents=True, exist_ok=True)
    APP_RESOURCES.mkdir(parents=True, exist_ok=True)
    changed = False
    changed = write_text_if_changed(APP_PLIST, app_info_plist()) or changed
    changed = write_text_if_changed(APP_PKGINFO, "APPL????", encoding="ascii") or changed
    changed = write_text_if_changed(APP_MAIN, app_main_source()) or changed
    changed = write_text_if_changed(APP_RESOURCES / "launcher.c", app_launcher_source()) or changed
    if changed or not APP_EXEC.exists():
        build_app_launcher()
        changed = True

    old_python_copy = APP_MACOS / "StickS3BridgePython"
    try:
        old_python_copy.unlink()
        changed = True
    except FileNotFoundError:
        pass

    if changed:
        sign_app_bundle(APP_DIR)
    return APP_DIR


def ensure_agent_app() -> Path:
    if app_bundle_current(AGENT_APP_DIR):
        return AGENT_APP_DIR
    source_app = ensure_bridge_app()
    AGENT_APP_DIR.parent.mkdir(parents=True, exist_ok=True)
    if AGENT_APP_DIR.exists():
        shutil.rmtree(AGENT_APP_DIR)
    shutil.copytree(source_app, AGENT_APP_DIR, symlinks=True)
    return AGENT_APP_DIR


def app_open_command(args: argparse.Namespace) -> list[str]:
    app_dir = ensure_agent_app()
    app_main = app_dir / "Contents" / "Resources" / "bridge_app_main.py"
    open_bin = shutil.which("open") or "/usr/bin/open"
    return [open_bin, "-n", "-g", str(app_dir), "--args", str(app_main), *bridge_args(args)]


def launchd_domain() -> str:
    return f"gui/{os.getuid()}"


def launchd_service() -> str:
    return f"{launchd_domain()}/{AGENT_LABEL}"


def agent_payload(args: argparse.Namespace) -> dict[str, Any]:
    app_dir = ensure_agent_app()
    app_main = app_dir / "Contents" / "Resources" / "bridge_app_main.py"
    open_bin = shutil.which("open") or "/usr/bin/open"
    return {
        "Label": AGENT_LABEL,
        "ProgramArguments": [open_bin, "-n", "-g", str(app_dir), "--args", str(app_main), *bridge_args(args)],
        "RunAtLoad": True,
        "LimitLoadToSessionType": "Aqua",
        "KeepAlive": {"Crashed": True},
        "ThrottleInterval": 10,
        "WorkingDirectory": str(Path.home()),
        "StandardOutPath": str(LOG_FILE),
        "StandardErrorPath": str(LOG_FILE),
        "EnvironmentVariables": {
            "STICKS3_REPO": str(REPO_ROOT),
            "STICKS3_RUNTIME_DIR": str(RUNTIME_DIR),
        },
    }


def launchctl(*args: str, check: bool = False, timeout: float = 8.0) -> subprocess.CompletedProcess[str]:
    command = ["/bin/launchctl", *args]
    try:
        return subprocess.run(
            command,
            text=True,
            capture_output=True,
            check=check,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired as exc:
        stdout = exc.stdout.decode("utf-8", errors="replace") if isinstance(exc.stdout, bytes) else (exc.stdout or "")
        stderr = exc.stderr.decode("utf-8", errors="replace") if isinstance(exc.stderr, bytes) else (exc.stderr or "launchctl timed out")
        return subprocess.CompletedProcess(command, 124, stdout, stderr)


def agent_loaded() -> bool:
    return launchctl("print", launchd_service(), timeout=2.0).returncode == 0


def status_payload() -> dict[str, Any]:
    pid = read_pid()
    process_running = bool(pid and pid_is_running(pid))
    if pid and not process_running:
        remove_stale_pid()
        pid = None

    payload = read_json(STATUS_FILE)
    payload["supervisor_state"] = "running" if process_running else "stopped"
    payload["supervisor_pid"] = pid
    payload["runtime_dir"] = str(RUNTIME_DIR)
    payload["log_file"] = str(LOG_FILE)
    payload["launch_agent_installed"] = AGENT_PLIST.exists()
    payload["launch_agent_loaded"] = None
    payload["launch_agent_plist"] = str(AGENT_PLIST)
    payload["launch_agent_app"] = str(AGENT_APP_DIR)
    return payload


def command_start(args: argparse.Namespace) -> int:
    pid = read_pid()
    if pid and pid_is_running(pid):
        print(f"bridge already running: pid {pid}")
        return 0
    if pid:
        remove_stale_pid()

    try:
        command = app_open_command(args)
    except RuntimeError as exc:
        write_status("error", error=str(exc))
        print(str(exc), file=sys.stderr)
        return 1

    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    write_status("starting", detail="Starting StickS3 desktop observer")
    with LOG_FILE.open("ab") as log:
        log.write(f"\n[{now_iso()}] starting bridge\n".encode("utf-8"))
        process = subprocess.Popen(
            command,
            cwd=str(REPO_ROOT),
            stdin=subprocess.DEVNULL,
            stdout=log,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )

    deadline = time.monotonic() + 6.0
    pid = None
    while time.monotonic() < deadline:
        pid = read_pid()
        if pid and pid_is_running(pid):
            break
        time.sleep(0.2)
    current = read_json(STATUS_FILE)
    if current.get("state") in {None, "starting", "error", "stopped"}:
        write_status("starting", detail=f"Started pid {pid}" if pid else "Started app launcher")
    print(f"started bridge: pid {pid}" if pid else "started bridge app launcher")
    return 0


def command_run(args: argparse.Namespace) -> int:
    try:
        command = bridge_command(args)
    except RuntimeError as exc:
        write_status("error", error=str(exc))
        print(str(exc), file=sys.stderr)
        return 1

    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(f"{os.getpid()}\n", encoding="utf-8")
    write_status("starting", detail="Running StickS3 desktop observer")
    os.chdir(REPO_ROOT)
    os.execv(command[0], command)
    return 1


def command_stop(_args: argparse.Namespace) -> int:
    pid = read_pid()
    if not pid:
        write_status("stopped", detail="Bridge is not running")
        print("bridge is not running")
        return 0
    if not pid_is_running(pid):
        remove_stale_pid()
        write_status("stopped", detail="Removed stale pid file")
        print("bridge was not running; removed stale pid file")
        return 0

    os.kill(pid, signal.SIGTERM)
    deadline = time.monotonic() + 6.0
    while time.monotonic() < deadline:
        if not pid_is_running(pid):
            remove_stale_pid()
            write_status("stopped", detail=f"Stopped pid {pid}")
            print(f"stopped bridge: pid {pid}")
            return 0
        time.sleep(0.2)

    write_status("error", error=f"Bridge pid {pid} did not exit after SIGTERM")
    print(f"bridge pid {pid} did not exit after SIGTERM", file=sys.stderr)
    return 1


def command_restart(args: argparse.Namespace) -> int:
    stop_code = command_stop(args)
    if stop_code != 0:
        return stop_code
    return command_start(args)


def command_ensure(args: argparse.Namespace) -> int:
    pid = read_pid()
    if pid and pid_is_running(pid):
        print(f"bridge already running: pid {pid}")
        return 0
    if pid:
        remove_stale_pid()

    current = read_json(STATUS_FILE)
    if current.get("state") in {"starting", "connecting"}:
        try:
            age = time.time() - STATUS_FILE.stat().st_mtime
        except OSError:
            age = 999.0
        if age < 30.0:
            print("bridge start already queued")
            return 0

    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    write_status("starting", detail="Menu auto-start queued")
    script = REPO_ROOT / "scripts" / "sticks3-macos-bridge"
    command = [str(script), "start", *supervisor_option_args(args)]
    with LOG_FILE.open("ab") as log:
        log.write(f"\n[{now_iso()}] menu auto-start queued\n".encode("utf-8"))
        subprocess.Popen(
            command,
            cwd=str(REPO_ROOT),
            stdin=subprocess.DEVNULL,
            stdout=log,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
    print("bridge start queued")
    return 0


def unload_agent_quietly() -> None:
    launchctl("bootout", launchd_service())
    if AGENT_PLIST.exists():
        launchctl("bootout", launchd_domain(), str(AGENT_PLIST))


def command_install_agent(args: argparse.Namespace) -> int:
    try:
        ensure_bridge_app()
    except RuntimeError as exc:
        write_status("error", error=str(exc))
        print(str(exc), file=sys.stderr)
        return 1

    unload_agent_quietly()
    pid = read_pid()
    if pid and pid_is_running(pid):
        command_stop(args)

    try:
        payload = agent_payload(args)
    except RuntimeError as exc:
        write_status("error", error=str(exc))
        print(str(exc), file=sys.stderr)
        return 1

    AGENT_PLIST.parent.mkdir(parents=True, exist_ok=True)
    AGENT_PLIST.write_bytes(plistlib.dumps(payload, sort_keys=False))
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    with LOG_FILE.open("ab") as log:
        log.write(f"\n[{now_iso()}] installing launch agent\n".encode("utf-8"))

    result = launchctl("bootstrap", launchd_domain(), str(AGENT_PLIST))
    if result.returncode != 0:
        write_status("error", error=result.stderr.strip() or result.stdout.strip() or "launchctl bootstrap failed")
        print(result.stderr.strip() or result.stdout.strip() or "launchctl bootstrap failed", file=sys.stderr)
        return result.returncode

    launchctl("kickstart", "-k", launchd_service())
    write_status("starting", detail="LaunchAgent installed and started")
    print(f"installed launch agent: {AGENT_PLIST}")
    return 0


def command_uninstall_agent(args: argparse.Namespace) -> int:
    unload_agent_quietly()
    try:
        AGENT_PLIST.unlink()
    except FileNotFoundError:
        pass
    command_stop(args)
    if AGENT_APP_DIR.exists():
        shutil.rmtree(AGENT_APP_DIR)
    write_status("stopped", detail="LaunchAgent uninstalled")
    print(f"uninstalled launch agent: {AGENT_PLIST}")
    return 0


def command_agent_status(_args: argparse.Namespace) -> int:
    payload = status_payload()
    loaded = agent_loaded()
    print(f"launch agent installed: {'yes' if AGENT_PLIST.exists() else 'no'}")
    print(f"launch agent loaded: {'yes' if loaded else 'no'}")
    print(f"plist: {AGENT_PLIST}")
    print(f"app: {AGENT_APP_DIR}")
    print(f"bridge supervisor: {payload.get('supervisor_state') or 'unknown'}")
    if payload.get("supervisor_pid"):
        print(f"pid: {payload['supervisor_pid']}")
    if payload.get("state"):
        print(f"device: {payload['state']}")
    if payload.get("error"):
        print(f"error: {payload['error']}")
    return 0


def command_status(args: argparse.Namespace) -> int:
    payload = status_payload()
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 0

    state = payload.get("state") or "unknown"
    supervisor = payload.get("supervisor_state")
    pid = payload.get("supervisor_pid")
    detail = payload.get("detail") or payload.get("last_message") or ""
    updated = payload.get("updated_at") or "never"
    print(f"bridge: {supervisor}" + (f" (pid {pid})" if pid else ""))
    print(f"device: {state}")
    print(f"updated: {updated}")
    if detail:
        print(f"detail: {detail}")
    if payload.get("error"):
        print(f"error: {payload['error']}")
    print(f"log: {LOG_FILE}")
    return 0


def add_bridge_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--log-level", default=os.environ.get("STICKS3_LOG_LEVEL", "INFO"))
    parser.add_argument("--scan-timeout", type=float, default=float(os.environ.get("STICKS3_SCAN_TIMEOUT", "15")))
    parser.add_argument("--poll-interval", type=float, default=float(os.environ.get("STICKS3_POLL_INTERVAL", "0.5")))
    parser.add_argument(
        "--heartbeat-interval",
        type=float,
        default=float(os.environ.get("STICKS3_HEARTBEAT_INTERVAL", "10")),
    )
    parser.add_argument(
        "--idle-heartbeat-interval",
        type=float,
        default=float(os.environ.get("STICKS3_IDLE_HEARTBEAT_INTERVAL", "45")),
    )
    parser.add_argument(
        "--reconnect-delay",
        type=float,
        default=float(os.environ.get("STICKS3_RECONNECT_DELAY", "1")),
    )
    parser.add_argument(
        "--max-reconnect-delay",
        type=float,
        default=float(os.environ.get("STICKS3_MAX_RECONNECT_DELAY", "3")),
    )
    parser.add_argument("--no-reconnect", dest="reconnect", action="store_false", default=True)
    parser.add_argument("--device-prefix", default=os.environ.get("STICKS3_DEVICE_PREFIX", "Codex-S3-"))
    parser.add_argument("--address", default=os.environ.get("STICKS3_ADDRESS"))
    parser.add_argument("--codex-home", default=os.environ.get("STICKS3_CODEX_HOME"))
    parser.add_argument("--sessions-dir", default=os.environ.get("STICKS3_SESSIONS_DIR"))
    parser.add_argument("--thread-id", default=os.environ.get("STICKS3_THREAD_ID"))
    parser.add_argument("--rollout", default=os.environ.get("STICKS3_ROLLOUT"))
    parser.add_argument("--fake-device", action="store_true", default=os.environ.get("STICKS3_FAKE_DEVICE") == "1")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage the StickS3 Codex Desktop observer on macOS.")
    subcommands = parser.add_subparsers(dest="command", required=True)

    start = subcommands.add_parser("start", help="Start the background bridge process.")
    add_bridge_options(start)
    start.set_defaults(func=command_start)

    run = subcommands.add_parser("run", help="Run the bridge in the foreground, for launchd.")
    add_bridge_options(run)
    run.set_defaults(func=command_run)

    stop = subcommands.add_parser("stop", help="Stop the bridge process started by this supervisor.")
    stop.set_defaults(func=command_stop)

    restart = subcommands.add_parser("restart", help="Restart the supervised bridge process.")
    add_bridge_options(restart)
    restart.set_defaults(func=command_restart)

    ensure = subcommands.add_parser("ensure", help="Queue a background bridge start when the supervisor is stopped.")
    add_bridge_options(ensure)
    ensure.set_defaults(func=command_ensure)

    install_agent = subcommands.add_parser("install-agent", help="Install and start a macOS LaunchAgent at login.")
    add_bridge_options(install_agent)
    install_agent.set_defaults(func=command_install_agent)

    uninstall_agent = subcommands.add_parser("uninstall-agent", help="Unload and remove the macOS LaunchAgent.")
    uninstall_agent.set_defaults(func=command_uninstall_agent)

    agent_status = subcommands.add_parser("agent-status", help="Print LaunchAgent installation/load status.")
    agent_status.set_defaults(func=command_agent_status)

    status = subcommands.add_parser("status", help="Print current bridge status.")
    status.add_argument("--json", action="store_true")
    status.set_defaults(func=command_status)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
